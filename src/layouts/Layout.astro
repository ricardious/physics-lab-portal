---
import "@/styles/global.css";
import SplashHeader from "@/components/organisms/SplashHeader";
import SiteFooter from "@/components/organisms/SiteFooter.astro";
import PdfModalViewer from "@/components/organisms/PdfModalViewer";

const base = import.meta.env.BASE_URL;
const assetBase = base.endsWith("/") ? base : `${base}/`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${assetBase}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>Departamento Física</title>

    <!-- Font Preloads -->
    <link
      rel="preload"
      href={`${assetBase}fonts/OpenSans-Light.ttf`}
      as="font"
      type="font/ttf"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href={`${assetBase}fonts/OpenSans-Bold.ttf`}
      as="font"
      type="font/ttf"
      crossorigin="anonymous"
    />

    <meta
      name="description"
      content="Página oficial del Departamento de Física de la Facultad de Ingeniería de la Universidad de San Carlos de Guatemala. Información sobre laboratorios, manuales, y actividades académicas."
    />

    <meta property="og:url" content="https://fisica.usac.edu.gt/fisica/" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Departamento de Física - USAC" />
    <meta
      property="og:description"
      content="Explora los recursos académicos, laboratorios y eventos del Departamento de Física de la USAC."
    />
    <meta
      property="og:image"
      content="https://fisica.usac.edu.gt/assets/og-imagen-fisica.jpg"
    />
    <meta property="og:locale" content="es_GT" />
    <meta property="og:site_name" content="Departamento de Física USAC" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Departamento de Física - USAC" />
    <meta
      name="twitter:description"
      content="Explora los recursos académicos, laboratorios y eventos del Departamento de Física de la USAC."
    />
    <meta
      name="twitter:image"
      content="https://fisica.usac.edu.gt/assets/og-imagen-fisica.jpg"
    />
  </head>
  <body class="min-h-screen bg-nebula text-white flex flex-col">
    <noscript>
      <div class="p-8 text-center text-gray-100 font-sans">
        <h1 class="text-2xl font-bold mb-4">¡Atención!</h1>
        <p class="text-lg">
          El <strong>Portal de Física - USAC</strong> requiere JavaScript para visualizar
          correctamente todos los elementos de la página.
        </p>
        <p class="mt-4">
          Por favor activa JavaScript en tu navegador para disfrutar de la mejor
          experiencia visual.
        </p>
      </div>
    </noscript>
    <SplashHeader client:load />
    <main class="w-full max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
      <slot />
    </main>
    <PdfModalViewer client:load />
    <SiteFooter />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }
</style>
