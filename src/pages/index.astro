---
import Layout from "@/layouts/Layout.astro";
import GlassCard from "@/components/atoms/GlassCard.astro";
import WelcomeText from "@/components/molecules/WelcomeText.astro";
import CardHeader from "@/components/molecules/CardHeader.astro";
import SoftwareList from "@/components/molecules/SoftwareList.astro";
import {
  academicDocuments,
  institutionalLinks,
  manualsAndPrograms,
  softwareTools,
} from "@/lib/constants/resources";

const quickAccess = [
  {
    id: "herramientas",
    label: "Herramientas",
    count: softwareTools.length,
    detail: "software, tutoriales y utilidades",
  },
  {
    id: "documentos",
    label: "Documentos",
    count: academicDocuments.length,
    detail: "plantillas, normas y guías",
  },
  {
    id: "manuales",
    label: "Manuales y programas",
    count: manualsAndPrograms.length,
    detail: "material por curso de laboratorio",
  },
];
---

<Layout>
  <WelcomeText class="mt-4" />

  <section class="mt-8 grid gap-4 md:grid-cols-3">
    {
      quickAccess.map((item, index) => (
        <a
          href={`#${item.id}`}
          class="group relative border border-white/10 bg-event-horizon/85 px-5 py-5 text-left shadow-[0_10px_30px_rgba(0,0,0,0.18)] transition-all duration-200 hover:-translate-y-1 hover:border-panel-accent/40"
        >
          <div class="absolute bottom-0 left-0 top-0 w-1 bg-panel-accent/70"></div>
          <p class="display-title pl-3 text-xs font-semibold text-panel-accent/80">
            0{index + 1}
          </p>
          <h2 class="mt-3 pl-3 text-lg font-semibold text-starlight-text">
            {item.label}
          </h2>
          <p class="mt-2 pl-3 text-sm text-starlight-text/62">{item.detail}</p>
          <p class="mt-5 pl-3 text-3xl font-bold text-starlight-text">
            {item.count}
          </p>
        </a>
      ))
    }
  </section>

  <section class="mt-8 grid gap-8 lg:grid-cols-[1.1fr_1.9fr]">
    <GlassCard class="text-white">
      <div class="space-y-8">
        <div>
          <p class="display-title text-xs font-semibold text-panel-accent/80">
            Información general
          </p>
          <h2 class="mt-3 text-2xl font-semibold text-starlight-text">
            Coordinación de Laboratorios
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-starlight-text/72">
            Coordinación de Laboratorios de Física, S-11, Oficina 201.
          </p>
        </div>

        <div class="border-l border-white/10 pl-4">
          <p class="display-title text-xs font-semibold text-panel-accent/80">
            Aviso
          </p>
          <p class="mt-3 text-sm leading-relaxed text-starlight-text/72">
            Por resolución de Junta Directiva, para congelar la nota de laboratorios de Física se requiere zona mínima desde el primer semestre de 2016.
          </p>
        </div>

        <div class="border-t border-white/8 pt-6">
          <p class="display-title text-xs font-semibold text-panel-accent/80">
            Enlaces institucionales
          </p>
          <div class="mt-4 space-y-3">
            {
              institutionalLinks.map((link) => (
                <a
                  href={link.url}
                  class="flex items-center justify-between border border-white/8 bg-blackhole-core/35 px-4 py-3 text-sm text-starlight-text/78 transition-colors duration-200 hover:border-panel-accent/30 hover:text-starlight-text"
                >
                  <span>{link.name}</span>
                  <span class="display-title text-[11px] text-panel-accent/72">
                    Ver
                  </span>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </GlassCard>

    <GlassCard id="herramientas" class="text-white">
      <CardHeader
        icon="fas fa-tools"
        title="Herramientas de análisis"
        description="Software técnico y materiales de apoyo para procesar datos, graficar resultados y preparar reportes de laboratorio."
      />
      <SoftwareList software={softwareTools} class="mt-6" />
    </GlassCard>
  </section>

  <section class="mt-8 grid gap-8 lg:grid-cols-2">
    <GlassCard id="documentos" class="text-white">
      <CardHeader
        icon="fas fa-file-alt"
        title="Documentos académicos"
        description="Plantillas, guías metodológicas y documentos base para redacción y presentación de informes."
      />
      <SoftwareList software={academicDocuments} class="mt-6" />
    </GlassCard>

    <GlassCard id="manuales" class="text-white">
      <CardHeader
        icon="fas fa-book"
        title="Manuales y programas"
        description="Material de consulta por nivel de laboratorio para ubicar prácticas, lineamientos y programas vigentes."
      />
      <SoftwareList software={manualsAndPrograms} class="mt-6" />
    </GlassCard>
  </section>
</Layout>
