---
export interface Props {
  class?: string;
  id?: string;
}

const { class: className = "", id } = Astro.props;
---

<div
  id={id}
  class={`relative w-full overflow-hidden border border-white/10 bg-event-horizon/90 p-7 shadow-[0_20px_50px_rgba(0,0,0,0.24)] transition-transform duration-300 ease-out hover:-translate-y-1 sm:p-8 lg:p-9 ${className}`}
>
  <div
    class="absolute inset-x-8 top-0 h-px bg-panel-accent/60"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 top-0 w-1 bg-panel-accent/75"
  >
  </div>

  <div class="relative z-10">
    <slot />
  </div>
</div>
