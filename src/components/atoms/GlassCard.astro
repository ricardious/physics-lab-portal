---
export interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div
  class={`max-w-md w-full bg-starfield-layer backdrop-blur-lg rounded-3xl shadow-2xl transform hover:scale-[1.02] transition-transform duration-500 ease-in-out p-8 relative overflow-hidden border border-starlight-text/20 ${className}`}
>
  <div
    class="absolute -top-20 -right-20 w-40 h-40 bg-galaxy-core rounded-full mix-blend-multiply filter blur-xl opacity-70"
  >
  </div>
  <div
    class="absolute -bottom-20 -left-20 w-40 h-40 bg-galaxy-core-dark rounded-full mix-blend-multiply filter blur-xl opacity-70"
  >
  </div>

  <div
    class="absolute inset-0 bg-gradient-to-br from-galaxy-core/10 via-transparent to-galaxy-core-dark/10 rounded-3xl"
  >
  </div>

  <div class="relative z-10">
    <slot />
  </div>
</div>
