---
const repoUrl = "https://github.com/ricardious/physics-lab-portal";
---

<footer class="mt-16 border-t border-white/10 bg-blackhole-core/60">
  <div class="mx-auto grid w-full max-w-7xl gap-8 px-4 py-10 text-sm sm:px-6 md:grid-cols-[2fr_1fr] md:px-8">
    <div class="space-y-4 text-starlight-text/72">
      <p class="display-title text-xs font-semibold text-panel-accent/80">
        Facultad de Ingeniería
      </p>
      <div class="space-y-2 leading-relaxed">
        <p>Universidad de San Carlos de Guatemala</p>
        <p>Departamento de Física</p>
        <p>Segundo Nivel Edificio T-1 | Ciudad Universitaria zona 12 | Guatemala C.A.</p>
        <p>Código postal: 01012 | Teléfono/Fax: (502) 2418-9117</p>
      </div>
    </div>

    <div class="space-y-4 text-starlight-text/72">
      <p class="display-title text-xs font-semibold text-panel-accent/80">
        Proyecto
      </p>
      <div class="space-y-3">
        <p>
          Sitio realizado por <span class="font-semibold text-starlight-text">Ricardious</span>.
        </p>
        <a
          href={repoUrl}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center border border-white/10 bg-event-horizon px-4 py-3 text-starlight-text transition-colors duration-200 hover:border-panel-accent/40 hover:text-panel-accent"
        >
          Ver repositorio en GitHub
        </a>
      </div>
    </div>
  </div>
</footer>
