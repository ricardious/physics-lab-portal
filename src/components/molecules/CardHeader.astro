---
import CardIcon from "@/components/atoms/CardIcon.astro";
import CardTitle from "@/components/atoms/CardTitle.astro";

export interface Props {
  icon: string;
  title: string;
  description?: string;
  class?: string;
}

const { icon, title, description, class: className = "" } = Astro.props;
---

<div class={`mb-8 flex items-start gap-5 border-b border-white/8 pb-7 ${className}`}>
  <CardIcon icon={icon} />
  <CardTitle title={title} description={description} />
</div>
