---
import IconContainer from "@/components/atoms/IconContainer.astro";

export interface Software {
  name: string;
  url: string;
  platform?: string;
  description?: string;
  type?: string;
  icon?: string;
}

export interface Props {
  software: Software[];
  class?: string;
}

const { software, class: className = "" } = Astro.props;

const listId = `resource-list-${Math.random().toString(36).slice(2, 10)}`;

