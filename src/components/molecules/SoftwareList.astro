  <circle cx="393.639" cy="87.515" r="17.384"/>
  <path d="M462.369 213.371c-14.459 0-27.491 6.218-36.57 16.117l-122.911-80.337a49.3 49.3 0 0 0 4.247-20.053c0-27.367-22.265-49.632-49.632-49.632-22.059 0-40.794 14.469-47.235 34.413L99.249 97.228c-.374-27.046-22.482-48.937-49.616-48.937C22.265 48.291 0 70.556 0 97.922c0 27.368 22.265 49.633 49.632 49.633 22.059 0 40.795-14.469 47.237-34.413l111.021 16.65c.344 24.859 19.049 45.347 43.141 48.501l3.358 29.344a8.05 8.05 0 0 0 8.907 7.079 8.047 8.047 0 0 0 7.079-8.908l-3.208-28.032c10.547-2.091 19.902-7.531 26.904-15.165l122.911 80.338a49.3 49.3 0 0 0-4.248 20.055 49.33 49.33 0 0 0 7.221 25.755l-101.912 87.355c-8.06-6.788-18.296-11.068-29.502-11.609l-15.146-132.331c-.505-4.415-4.51-7.583-8.908-7.078a8.047 8.047 0 0 0-7.079 8.908l15.147 132.337c-20.794 5.917-36.073 25.069-36.073 47.735 0 27.367 22.266 49.631 49.633 49.631s49.633-22.264 49.633-49.631a49.33 49.33 0 0 0-7.222-25.757l101.913-87.355c8.637 7.275 19.776 11.671 31.926 11.671 27.367 0 49.632-22.264 49.632-49.631.003-27.367-22.262-49.633-49.628-49.633M49.632 131.464c-18.495 0-33.541-15.047-33.541-33.542 0-18.494 15.045-33.541 33.541-33.541s33.543 15.047 33.543 33.541c-.001 18.496-15.047 33.542-33.543 33.542m207.871 31.174c-18.493 0-33.54-15.047-33.54-33.541s15.045-33.541 33.54-33.541 33.541 15.047 33.541 33.541c0 18.495-15.046 33.541-33.541 33.541m28.614 284.98c-18.495 0-33.543-15.045-33.543-33.54s15.047-33.542 33.543-33.542c18.494 0 33.542 15.047 33.542 33.542-.001 18.493-15.047 33.54-33.542 33.54m176.252-151.073c-18.495 0-33.543-15.045-33.543-33.54s15.047-33.543 33.543-33.543c18.494 0 33.541 15.047 33.541 33.543-.001 18.494-15.047 33.54-33.541 33.54"/>
  </svg>`,
  software: `<svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="none" viewBox="0 0 48 48"><g stroke="currentColor" stroke-width="3"><path d="M44.829 17.336c-.128 1.718-1.396 3.114-3.108 3.32C40.23 20.835 38.245 21 36 21s-4.229-.165-5.721-.344c-1.712-.206-2.98-1.602-3.108-3.32-.09-1.224-.171-2.64-.171-3.836 0-4.198 3.375-7.45 7.573-7.493a142 142 0 0 1 2.854 0C41.625 6.049 45 9.302 45 13.5c0 1.195-.08 2.612-.171 3.836Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M36 2v4m-3 7v1m6-1v1M16 27a5 5 0 1 0 10 0 5 5 0 1 0-10 0M5.423 27C1.504 20.526.633 14.328 4.48 10.48s10.046-2.976 16.52.943c-2.89 1.75-5.837 4.108-8.653 6.924S7.173 24.109 5.423 27m0 0C1.504 33.474.633 39.672 4.48 43.52s10.046 2.976 16.52-.943M5.423 27c1.75 2.89 4.108 5.837 6.924 8.653s5.762 5.174 8.653 6.924m0 0c6.474 3.919 12.672 4.79 16.52.943s2.976-10.046-.943-16.52c-1.75 2.89-4.108 5.837-6.924 8.653S23.891 40.827 21 42.577"/></g>
  </svg>`,
  document: `<svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
  <path d="M7 3.75h7.75L19 8v12.25A1.75 1.75 0 0 1 17.25 22h-10.5A1.75 1.75 0 0 1 5 20.25V5.5A1.75 1.75 0 0 1 6.75 3.75Z"/>
  <path d="M14 3.75V8h4.25"/>
  <path d="M8 12h8M8 16h6"/>
  </svg>`,
};

function getIconHtml(program: Software) {
  if (program.icon) return program.icon;
  const type = program.type || "software";
  return defaultIcons[type as keyof typeof defaultIcons] || defaultIcons.software;
}

function isPdf(url: string) {
  return url.toLowerCase().endsWith(".pdf");
}

function isExternal(url: string) {
  return /^https?:\/\//.test(url);
}
---

<div id={listId} class={`software-list ${className}`}>
  <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
    {
      software.map((program) =>
        isPdf(program.url) ? (
          <button
            type="button"
            class="group relative flex w-full items-center gap-4 overflow-hidden border border-white/8 bg-blackhole-core/40 px-4 py-4 text-left transition-all duration-200 hover:-translate-y-1 hover:border-panel-accent/30 hover:bg-blackhole-core/60"
            data-pdf-trigger
            data-pdf-url={program.url}
            data-pdf-title={program.name}
          >
            <div class="absolute bottom-0 left-0 top-0 w-1 bg-panel-accent/55"></div>
            <IconContainer iconHtml={getIconHtml(program)} class="mr-4" />
            <div class="flex-1">
              <h4 class="text-sm font-semibold text-starlight-text transition-colors duration-200 group-hover:text-panel-accent sm:text-base">
                {program.name}
              </h4>
              <p class="mt-2 text-xs text-starlight-text/52 transition-colors duration-200 group-hover:text-starlight-text/72">
                <span class="mr-2 inline-flex border border-panel-accent/16 bg-panel-accent/10 px-2 py-0.5 text-[11px] uppercase tracking-[0.16em] text-panel-accent/80">
                  PDF
                </span>
                Vista previa y descarga
              </p>
            </div>
            <div class="display-title text-[11px] text-starlight-text/38 transition-colors duration-200 group-hover:text-panel-accent/72">
              Ver
            </div>
          </button>
        ) : (
          <a
            href={isExternal(program.url) ? program.url : import.meta.env.BASE_URL + (program.url.startsWith('/') ? program.url.slice(1) : program.url)}
            class="group relative flex items-center gap-4 overflow-hidden border border-white/8 bg-blackhole-core/40 px-4 py-4 transition-all duration-200 hover:-translate-y-1 hover:border-panel-accent/30 hover:bg-blackhole-core/60"
            download={isExternal(program.url) ? undefined : true}
            target={isExternal(program.url) ? "_blank" : undefined}
            rel={isExternal(program.url) ? "noreferrer" : undefined}
          >
            <div class="absolute bottom-0 left-0 top-0 w-1 bg-panel-accent/55"></div>
            <IconContainer iconHtml={getIconHtml(program)} class="mr-4" />
            <div class="flex-1">
              <h4 class="text-sm font-semibold text-starlight-text transition-colors duration-200 group-hover:text-panel-accent sm:text-base">
                {program.name}
              </h4>
              {(program.platform || program.description) && (
                <p class="mt-2 text-xs text-starlight-text/52 transition-colors duration-200 group-hover:text-starlight-text/72">
                  {program.platform && (
                    <span class="mr-2 inline-flex border border-panel-accent/16 bg-panel-accent/10 px-2 py-0.5 text-[11px] uppercase tracking-[0.16em] text-panel-accent/80">
                      {program.platform}
                    </span>
                  )}
                  {program.description}
                </p>
              )}
            </div>
            <div class="display-title text-[11px] text-starlight-text/38 transition-colors duration-200 group-hover:text-panel-accent/72">
              {isExternal(program.url) ? "Abrir" : "Descargar"}
            </div>
          </a>
        ),
      )
    }
  </div>
</div>
